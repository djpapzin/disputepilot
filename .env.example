# DisputePilot example configuration only. Do not put real secrets here.

# UiPath Automation Cloud / Maestro Case placeholders
UIPATH_TENANT_URL=https://example.uipath.com
UIPATH_CLIENT_ID=replace-with-uipath-client-id
UIPATH_CLIENT_SECRET=replace-with-uipath-client-secret
UIPATH_QUEUE_NAME=DisputePilot Cases
UIPATH_WEBHOOK_URL=https://example.uipath.com/workflows/disputepilot/handoff
UIPATH_AUTH_TOKEN=replace-with-uipath-auth-token

# AI provider placeholder
AI_PROVIDER=replace-with-provider-name
AI_API_KEY=replace-with-ai-api-key

# Telegram approval routing placeholders
DISPUTEPILOT_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
DISPUTEPILOT_TELEGRAM_APPROVAL_CHAT_ID=replace-with-telegram-chat-or-channel-id
DISPUTEPILOT_TELEGRAM_TOPIC_ID=replace-with-confirmed-topic-id
DISPUTEPILOT_TELEGRAM_ALLOWED_USER_IDS=123456,987654
DISPUTEPILOT_TELEGRAM_CALLBACK_AUDIT_DB_PATH=./.runtime/telegram_callback_audit.sqlite3

# Demo-only mode must stay true until real integrations are explicitly approved.
DISPUTEPILOT_DEMO_MODE=true
